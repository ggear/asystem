WRANGLE_HTTP_PORT=32410
WRANGLE_RUN_TIMEOUT_SECONDS=300
WRANGLE_NETWORK_TIMEOUT_SECONDS=20
WRANGLE_STACK_DUMP_FILE=/tmp/wrangle-stack.log
WRANGLE_DATABASE_HOST=$POSTGRES_IP
WRANGLE_DATABASE_PORT=$POSTGRES_API_PORT
WRANGLE_DATABASE_USER=$POSTGRES_DATABASE_WRANGLE
WRANGLE_DATABASE_PASSWORD=$POSTGRES_KEY_WRANGLE
